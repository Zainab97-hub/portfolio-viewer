<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
    <link rel="stylesheet" href="/style.css">
    <title>Portfolio Viewer</title>
</head>
<body>

    <nav>
        <h4> Portfolio Viewer</h4>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/profile">Profil</a></li>
            <li><a href="/admin">Admin</a></li>
            <li><a href="/auth/logout">Ausloggen</a></li>
        </ul>
        <span id="nbtn" class="navbtn">&#9776;</span>
    </nav>

    <div id="mySidenav" class="sidenav">
        <span class="closebtn">&#9664;</span>
        <div id="mySidenSpan">
            <span id="verwaltung-btn">Users verwalten</span>
            <span id="start-btn">Zur Start Seite</span>
            <span class="menu" onclick="window.location.href='https://mr.uni-wuppertal.de/mr/kontakt-service/sekretariat'">Kontakt</span>
            <span class="menu" onclick="window.location.href='https://mr.uni-wuppertal.de/impressum'">Impressum</span>   
            <span class="menu" onclick="window.location.href='https://mr.uni-wuppertal.de/datenschutz'">Datenschutz</span>
            <span class="menu" onclick="window.location.href='https:'">LICENSE</span>
        </div>
    </div>

    <div class="container mt-4">
        <div class="row">
            <div class="col-4">
                <div class="card">
                    <div class="avatar-ctn">
                        <img src="/avatar.png" class="avatar" alt="user profile picture">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">{{user_details.name}}</h5>
                        <p class="card-text">
                            Einige kurze Beispieltexte, die auf dem Kartentitel aufbauen und den Großteil des Karteninhalts ausmachen. 
                        </p>
                        <a href="#" class="btn btn-primary">{{user_details.email}}</a>
                    </div>
                </div>
            </div>

            <div class="col-8">
                <div class="card text-center">
                    <div class="card-header">
                        Profil Seite
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">Hey {{user_details.name}} Willkommen zurück</h5>
                        <p class="card-text">
                            Dies ist Ihre Profilseite, auf der Sie alle Informationen zu Ihrer Person hinzufügen können.
                        </p>
                        <a href="" class=" btn btn-primary">Irgendwohin gehen</a>
                    </div>
                    <div class="card-footer text-muted">
                        Portfolio Viewer - Project
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js" integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN" crossorigin="anonymous"></script>
    <script src="/navigation.js"></script>
</body>
</html>
